{
  "name": "ecom",
  "version": "1.0.0",
  "description": "ecommerce rest api",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "nodemon server.js",
    "client": "npm start --prefix ./client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "sonarqube": "sonar-scanner",
    "test": "npm run test:backend && npm run test:frontend && npm run test:coverage:merge",
    "test:frontend": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.frontend.config.js",
    "test:backend": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.backend.config.js",
    "test:integration-backend": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.integration-backend.config.js",
    "test:integration-frontend": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.integration-frontend.config.js",
    "test:integration": "npm run test:integration-backend && npm run test:integration-frontend",
    "test:ui": "playwright test",
    "test:coverage:merge": "node scripts/merge-lcov.js",
    "test:load": "npm run test:load:product && npm run test:load:search && npm run test:load:auth",
    "test:load:product": "node -e \"const fs=require('fs');fs.rmSync('load-tests/results/product-browsing-results.csv',{force:true});fs.rmSync('load-tests/results/product-browsing-report',{recursive:true,force:true});\" && jmeter -n -t load-tests/product-browsing.jmx -l load-tests/results/product-browsing-results.csv -e -o load-tests/results/product-browsing-report",
    "test:load:search": "node -e \"const fs=require('fs');fs.rmSync('load-tests/results/search-filter-results.csv',{force:true});fs.rmSync('load-tests/results/search-filter-report',{recursive:true,force:true});\" && jmeter -n -t load-tests/search-filter.jmx -l load-tests/results/search-filter-results.csv -e -o load-tests/results/search-filter-report",
    "test:load:auth": "node load-tests/cleanup-test-users.js && node -e \"const fs=require('fs');fs.rmSync('load-tests/results/authentication-results.csv',{force:true});fs.rmSync('load-tests/results/authentication-report',{recursive:true,force:true});\" && jmeter -n -t load-tests/authentication.jmx -l load-tests/results/authentication-results.csv -e -o load-tests/results/authentication-report",
    "test:stress": "npm run test:stress:product && npm run test:stress:search && npm run test:stress:auth && npm run test:stress:category",
    "test:stress:product": "node -e \"const fs=require('fs');fs.rmSync('stress-tests/results/product-browsing-stress-results.csv',{force:true});fs.rmSync('stress-tests/results/product-browsing-stress-report',{recursive:true,force:true});\" && jmeter -n -t stress-tests/product-browsing-stress.jmx -l stress-tests/results/product-browsing-stress-results.csv -e -o stress-tests/results/product-browsing-stress-report",
    "test:stress:search": "node -e \"const fs=require('fs');fs.rmSync('stress-tests/results/search-filter-stress-results.csv',{force:true});fs.rmSync('stress-tests/results/search-filter-stress-report',{recursive:true,force:true});\" && jmeter -n -t stress-tests/search-filter-stress.jmx -l stress-tests/results/search-filter-stress-results.csv -e -o stress-tests/results/search-filter-stress-report",
    "test:stress:auth": "node stress-tests/cleanup-stress-users.js && node -e \"const fs=require('fs');fs.rmSync('stress-tests/results/authentication-stress-results.csv',{force:true});fs.rmSync('stress-tests/results/authentication-stress-report',{recursive:true,force:true});\" && jmeter -n -t stress-tests/authentication-stress.jmx -l stress-tests/results/authentication-stress-results.csv -e -o stress-tests/results/authentication-stress-report",
    "test:stress:category": "node -e \"const fs=require('fs');fs.rmSync('stress-tests/results/category-stress-results.csv',{force:true});fs.rmSync('stress-tests/results/category-stress-report',{recursive:true,force:true});\" && jmeter -n -t stress-tests/category-stress.jmx -l stress-tests/results/category-stress-results.csv -e -o stress-tests/results/category-stress-report"
  },
  "keywords": [],
  "author": "RP",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "braintree": "^3.22.0",
    "colors": "^1.4.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "date-fns": "^3.3.1",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-formidable": "^1.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.3.0",
    "mongoose": "^8.1.2",
    "morgan": "^1.10.0",
    "nodemon": "^3.0.3",
    "react-icons": "^5.0.1",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@babel/core": "^7.24.5",
    "@babel/preset-env": "^7.24.5",
    "@babel/preset-react": "^7.24.1",
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.12.12",
    "babel-jest": "^29.7.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "mongodb-memory-server": "^11.0.1",
    "sonarqube-scanner": "^4.3.5"
  }
}
